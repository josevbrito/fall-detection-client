# .env.lan.example — CLIENTE (Máquina B) apontando para o ThingsBoard local
# que roda na Máquina A (servidor) via Docker, pela rede local (LAN).
#
# Uso na Máquina B:
#   cp .env.lan.example .env
#   # edite TB_HOST com o IP da Máquina A na rede (ver runbook)
#
# Diferença para o modo Cloud: aqui é self-hosted, então NÃO é modo cloud
# (TB_CLOUD=false) e o provisionamento usa o fluxo de sysadmin normal.

# --- NÃO é cloud: usa o fluxo sysadmin -> cria tenant -> impersona ---
TB_CLOUD=false

# --- Endereço do servidor ThingsBoard (Máquina A) ---
# Linux nativo: IP da Máquina A na LAN (ex: 192.168.0.42).
# Se a Máquina A for Windows+WSL2: use o IP do WINDOWS na LAN (não o do WSL),
# e configure o port forwarding (netsh) — veja o runbook.
TB_HOST=192.168.0.42
TB_HTTP_SCHEME=http     # local, sem TLS
TB_HTTP_PORT=8090
TB_MQTT_PORT=1883
TB_MQTT_TLS=false

# Arquivo de tokens separado para o cenário LAN (não colide com local/cloud).
TB_TOKENS_FILE=device_tokens.lan.json

# --- Credenciais (devem casar com o servidor da Máquina A) ---
# sysadmin é o padrão da imagem tb-postgres; o tenant é criado pelo provision.
POSTGRES_USER=thingsboard
POSTGRES_PASSWORD=thingsboard2026
TB_ADMIN_EMAIL=sysadmin@thingsboard.org
TB_ADMIN_PASSWORD=sysadmin
TB_TENANT_EMAIL=fall-tenant@thingsboard.org
TB_TENANT_PASSWORD=tenant2026
