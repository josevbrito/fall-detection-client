# .env.thingsboard-cloud.example
# -------------------------------
# Aponta os scripts para o ThingsBoard Cloud gerenciado (thingsboard.cloud).
# Uso:
#   cp .env.thingsboard-cloud.example .env
#   # edite TB_TENANT_EMAIL / TB_TENANT_PASSWORD com SUA conta do thingsboard.cloud
#
# Para voltar ao modo local, restaure o .env original (TB_HOST=localhost etc).

# --- Modo Cloud ---
# Liga o login direto como tenant admin (sem sysadmin / sem criar tenant).
TB_CLOUD=true

# Arquivo de tokens separado, para não colidir com o device_tokens.json do
# teste local (que tem 110k devices da instância local, inválidos na nuvem).
TB_TOKENS_FILE=device_tokens.cloud.json

# --- HTTP (provisionamento, dashboard, REST API) ---
TB_HOST=thingsboard.cloud
TB_HTTP_SCHEME=https
TB_HTTP_PORT=443

# --- MQTT (publicação de telemetria) ---
# No Cloud o broker MQTT fica num host diferente do HTTP.
TB_MQTT_HOST=mqtt.thingsboard.cloud
TB_MQTT_PORT=8883        # 8883 = MQTT sobre TLS (recomendado). 1883 = texto puro.
TB_MQTT_TLS=true

# --- Sua conta do ThingsBoard Cloud (a que você usou no signup) ---
# No Cloud, estas credenciais SÃO o seu login de tenant admin.
TB_TENANT_EMAIL=seu-email@exemplo.com
TB_TENANT_PASSWORD=sua-senha-do-thingsboard-cloud
