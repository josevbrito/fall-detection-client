# .env.example — CLIENTE (load test). Copie para .env e ajuste:
#   cp .env.example .env
#
# Este arquivo é o modo LAN (apontando para o servidor fall-detection-cloud na
# rede local). Para outros cenários, use:
#   .env.lan.example              -> servidor na rede local (este)
#   .env.thingsboard-cloud.example -> ThingsBoard Cloud gerenciado

# Não é cloud gerenciado: provisiona via fluxo sysadmin.
TB_CLOUD=false

# IP da Máquina A (servidor ThingsBoard) na rede local.
TB_HOST=192.168.0.42
TB_HTTP_SCHEME=http
TB_HTTP_PORT=8090
TB_MQTT_PORT=1883
TB_MQTT_TLS=false

# Arquivo de tokens (separado por cenário).
TB_TOKENS_FILE=device_tokens.lan.json

# Credenciais (devem casar com o servidor).
POSTGRES_USER=thingsboard
POSTGRES_PASSWORD=thingsboard2026
TB_ADMIN_EMAIL=sysadmin@thingsboard.org
TB_ADMIN_PASSWORD=sysadmin
TB_TENANT_EMAIL=fall-tenant@thingsboard.org
TB_TENANT_PASSWORD=tenant2026
